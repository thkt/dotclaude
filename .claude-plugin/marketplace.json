        "./skills/think/SKILL.md",
        "./skills/research/SKILL.md",
        "./skills/probe/SKILL.md",
        "./skills/slice/SKILL.md"
      ],
      "agents": [
        "./agents/architects/architect-feature.md",
        "./agents/explorers/explorer-feature.md",
        "./agents/critics/critic-design.md"
      ]
