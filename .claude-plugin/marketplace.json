      "name": "plan",
      "source": "./",
      "description": "Planning and design: /outcome for outcome definition, /think for design exploration and SOW/Spec generation, /research for technical investigation, /probe for repository spec extraction, /slice for breaking plans into vertical-slice issues, plus architecture agents",
      "version": "3.0.0",
      "author": {
        "name": "thkt",
        "url": "https://github.com/thkt"
      },
      "license": "MIT",
      "keywords": ["planning", "design", "outcome", "sow", "spec", "architecture", "research"],
      "category": "Planning",
      "commands": [
