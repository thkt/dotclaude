{
  "name": "Claude Code Dev Container",
  "image": "ghcr.io/creanciel/deck:latest",

  // Prepare auth files on host (runs before container starts)
  "initializeCommand": "mkdir -p ~/.claude && touch ~/.claude.json",

  // Mount authentication and Claude settings
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],

  // Install Claude Code after container creation
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code",

  // VSCode extensions
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Container user
  "remoteUser": "vscode",

  // Port forwarding (customize as needed)
  "forwardPorts": [3000, 5173, 8080],

  // Environment variables (customize as needed)
  "containerEnv": {
    "CLAUDE_CODE_SKIP_UPDATE_CHECK": "true"
  }
}
