{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"endOfLine": "lf",
	"sortImports": {
		"groups": ["builtin", "external", "internal", "parent", "sibling"]
	},
	"sortPackageJson": true,
	"overrides": [
		{
			"files": ["*.md", "*.mdx"],
			"options": {
				"printWidth": 80,
				"proseWrap": "always"
			}
		}
	],
	"ignorePatterns": ["dist", "build", "*.generated.*"]
}
